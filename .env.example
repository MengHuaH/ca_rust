# VisualEngine.RS 环境变量配置模板
# 复制此文件为 .env 并根据实际环境进行配置

# ============================================================================
# 服务器配置
# ============================================================================

# 服务器监听地址
# 默认: localhost (仅本地访问)
# 生产环境: 0.0.0.0 (允许外部访问)
SERVER_HOST=localhost

# 服务器监听端口
# 默认: 3000
# 注意: 如果使用80/443端口需要管理员权限
SERVER_PORT=3000

# 服务器工作线程数
# 默认: 4 (根据CPU核心数调整)
# 建议: CPU核心数 * 2
SERVER_WORKERS=4

# ============================================================================
# 日志配置
# ============================================================================

# 日志级别
# 可选值: error, warn, info, debug, trace
# 开发环境: debug
# 生产环境: warn 或 info
LOG_LEVEL=info

# 日志格式
# 可选值: json, pretty
# json: 结构化日志，适合文件存储和日志分析
# pretty: 美化格式，适合控制台查看
LOG_FORMAT=json

# 日志轮转策略
# 可选值: daily, hourly, minutely, never
# daily: 每天轮转(生产环境推荐)
# hourly: 每小时轮转
# minutely: 每分钟轮转(调试使用)
# never: 不轮转(单个文件)
LOG_ROTATION=daily

# 日志文件存储目录
# 默认: ./logs (项目根目录下的logs文件夹)
# 生产环境: /var/log/visualengine
LOG_DIRECTORY=./logs

# 日志文件基础名称
# 默认: CA.log
# 轮转后的文件格式: CA.log.2024-01-01
LOG_FILENAME=CA.log

# ============================================================================
# 数据库配置 (PostgreSQL)
# ============================================================================

# 数据库服务器地址
# 默认: localhost
# 生产环境: 数据库服务器IP或域名
DB_HOST=localhost

# 数据库服务器端口
# PostgreSQL默认: 5432
# MySQL默认: 3306
# SQL Server默认: 1433
DB_PORT=5432

# 数据库用户名
# PostgreSQL默认: postgres
# MySQL默认: root
# 生产环境: 使用专用用户
DB_USERNAME=postgres

# 数据库密码
# 生产环境: 使用强密码
DB_PASSWORD=password

# 数据库名称
# 默认: db_default
# 生产环境: 有意义的数据库名称
DB_NAME=db_default

# 数据库连接池最大连接数
# 默认: 10
# 根据服务器资源和并发需求调整
DB_MAX_CONNECTIONS=10

# 数据库连接池最小连接数
# 默认: 2
# 保持的最小空闲连接数
DB_MIN_CONNECTIONS=2

# 获取连接超时时间(秒)
# 默认: 30
# 连接池获取连接的最大等待时间
DB_ACQUIRE_TIMEOUT=30

# 连接空闲超时时间(秒)
# 默认: 300 (5分钟)
# 连接在池中空闲的最大时间
DB_IDLE_TIMEOUT=300

# 连接最大生命周期(秒)
# 默认: 1800 (30分钟)
# 连接的最大存活时间
DB_MAX_LIFETIME=1800

# 连接重试最大尝试次数
# 默认: 5
# 数据库连接失败时的重试次数
DB_RETRY_MAX_ATTEMPTS=5

# 连接重试基础延迟(秒)
# 默认: 5
# 第一次重试的延迟时间
DB_RETRY_BASE_DELAY=5

# 连接重试延迟乘数
# 默认: 5
# 每次重试延迟时间的乘数(指数退避)
DB_RETRY_DELAY_MULTIPLIER=5

# ============================================================================
# Swagger/OpenAPI 配置
# ============================================================================

# Swagger UI访问路径
# 默认: /swagger-ui
# 访问地址: http://localhost:3000/swagger-ui
SWAGGER_UI_URL=/swagger-ui

# OpenAPI JSON文档路径
# 默认: /api-docs/openapi.json
# 访问地址: http://localhost:3000/api-docs/openapi.json
SWAGGER_UI_OPENAPI_URL=/api-docs/openapi.json
